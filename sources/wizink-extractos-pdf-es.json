{
  "id": "wizink-extractos-pdf-es",
  "name": "WiZink España — extractos (PDF)",
  "service": "wizink",
  "trust": "first-party",
  "domain": "wizink.es",
  "country": "ES",
  "version": "2026-07-07",
  "currency": "EUR",
  "categories": [
    "banking"
  ],
  "match": [
    "https://www.wizink.es/*"
  ],
  "auth": {
    "mode": "cookie",
    "replayHeaders": [],
    "resetCookies": true,
    "loginUrl": "https://www.wizink.es/login"
  },
  "api": {
    "host": "https://www.wizink.es",
    "csrf": {
      "path": "/clientes/posicion-global",
      "match": "securityToken['\"]?\\s*(?:value=|:)\\s*['\"]([A-Za-z0-9]{12,})"
    },
    "groups": {
      "from": "html",
      "path": "/cs/Satellite",
      "method": "POST",
      "params": {
        "pagename": "ECOM_SiteEntry/WZPRI/NewGlobalPosition"
      },
      "body": "ECOM_Page_Category=New Global Position&ECOM_Page_Sub_Category=New Global Position&securityToken={csrf}",
      "rows": {
        "each": "goToCardDetail\\('([^']+)',\\s*'([^']+)'[\\s\\S]{0,180}?c-card__summary[\\s\\S]{0,150}?card-product-name[^>]*>(?:<span[^>]*>[^<]*</span>)?\\s*([^<]+?)\\s*</span>[\\s\\S]{0,200}?card-security-code[^>]*>(?:<span[^>]*>[^<]*</span>)?\\s*([^<]*\\d{4})",
        "fields": {
          "accountNumber": {
            "group": 1
          },
          "cardNumber": {
            "group": 2
          },
          "name": {
            "group": 3
          },
          "mask": {
            "group": 4
          }
        }
      },
      "fields": {
        "id": "accountNumber",
        "accountNumber": "accountNumber",
        "cardNumber": "cardNumber",
        "name": "name",
        "mask": "mask"
      }
    },
    "list": {
      "from": "html",
      "path": "/cs/Satellite",
      "method": "POST",
      "paging": "none",
      "params": {
        "pagename": "ECOM_SiteEntry/WZPRI/CardDetail/ExtractOnScreen"
      },
      "body": "cardNumber={group.cardNumber}&accountNumber={group.accountNumber}&securityToken={csrf}",
      "rows": {
        "each": "<option[^>]*data-statementDate=\"([^\"]+)\"[^>]*data-inRepository=\"true\"[^>]*data-docId=\"([^\"]+)\"[^>]*data-fileName=\"([^\"]+)\"",
        "fields": {
          "statementDate": {
            "group": 1
          },
          "docId": {
            "group": 2
          },
          "fileName": {
            "group": 3
          }
        }
      }
    },
    "pdf": {
      "path": "/cs/Satellite/{fileName}?pagename=ECOM_SiteEntry/WZPRI/DownloadIC2File&d=Touch&documentId={docId}&fileName={fileName}&statementDate={statementDate}&accountNumber={group.accountNumber}&customerNumber=null&securityToken={csrf}",
      "method": "GET",
      "ext": "pdf"
    }
  },
  "fields": {
    "internalId": "{group.accountNumber}|{statementDate}",
    "date": "statementDate",
    "account": "{group.accountNumber}"
  },
  "schema": "invoice@1"
}
