{
  "id": "leroymerlin-es",
  "name": "Leroy Merlin España",
  "service": "leroymerlin",
  "trust": "community",
  "domain": "leroymerlin.es",
  "country": "ES",
  "categories": [
    "diy"
  ],
  "match": [
    "https://www.leroymerlin.es/*"
  ],
  "openUrl": "https://www.leroymerlin.es/mi-cuenta/mis-compras/historial",
  "auth": {
    "mode": "cookie",
    "replayHeaders": [],
    "loginUrl": "https://www.leroymerlin.es/login.html"
  },
  "itemLabel": "Pedido {internalId}",
  "api": {
    "host": "https://www.leroymerlin.es"
  },
  "streams": [
    {
      "id": "tickets",
      "name": "Tickets de tienda",
      "schema": "receipt@1",
      "categories": [
        "diy"
      ],
      "api": {
        "list": {
          "headers": {
            "content-type": "application/json"
          },
          "itemsPath": "receipts",
          "pageParam": "yearOffset",
          "pageStart": 2,
          "paging": "page",
          "params": {
            "page": "0",
            "size": "10"
          },
          "path": "/customer-space-module/services/customer-after-sales-backend/me/receipts"
        },
        "detail": {
          "headers": {
            "content-type": "application/json"
          },
          "method": "GET",
          "path": "/customer-space-module/services/customer-after-sales-backend/me/receipts/{internalId}"
        }
      },
      "fields": {
        "date": "date",
        "internalId": "id",
        "number": "number",
        "storeName": "store.storeName",
        "total": "totalPriceIncludingVAT.amount"
      }
    },
    {
      "id": "pedidos",
      "name": "Pedidos online",
      "schema": "receipt@1",
      "categories": [
        "diy"
      ],
      "api": {
        "list": {
          "headers": {
            "content-type": "application/json"
          },
          "path": "/order-followup/backend/v2/orders",
          "paging": "none",
          "itemsPath": "$",
          "keep": {
            "field": "orderPlaceType",
            "values": [
              "ONLINE"
            ]
          }
        }
      },
      "fields": {
        "internalId": "orderPartNumber",
        "date": "parentOrder.createdAt",
        "total": "price.totalAmount",
        "storeName": "vendors.0.name"
      }
    }
  ],
  "version": "2026-07-10",
  "minVersion": "0.1.54",
  "changelog": [
    {
      "version": "2026-07-10",
      "changes": "Añade compras online (stream «Pedidos online» vía /order-followup/backend/v2/orders, filtradas a ONLINE) junto a los tickets de tienda existentes; fuente multi-salida (streams)."
    },
    {
      "version": "2026-07-08",
      "changes": "Recibos vía API JSON (cookie)."
    }
  ]
}
